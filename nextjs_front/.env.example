프로젝트 최상단에 .env 파일을 만들고 아래내용 그대로 복붙

# Next.js 환경 변수 설정
NEXT_PUBLIC_SERVER_URL=http://localhost:8080
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:8080/ws-guest-chat
NEXT_PUBLIC_GOOGLE_MAP_KEY=구글맵 키
NEXT_PUBLIC_GOOGLE_MAP_ID=구글맵 ID(없이 될수도 있음)
NEXT_PUBLIC_KAKAO_MAP_KEY=여기에_카카오_JavaScript_키_입력
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:8080/ws-guest-chat

# 로그인전 숙소 테스트용 userId 테스트용. 각자 테스트할 userId 입력하시면 됩니다.
NEXT_PUBLIC_TEMP_USER_ID=2

