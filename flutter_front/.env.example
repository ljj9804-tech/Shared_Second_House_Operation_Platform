프로젝트 최상단에 .env 파일을 만들고 아래내용 그대로 복붙

# Flutter 환경 변수 설정
# [에뮬레이터 사용자] 아래 값 그대로 사용 (수정 불필요)
# [실물 기기 사용자]  ipconfig로 확인한 본인 PC IPv4 주소로 변경
#   예) PUBLIC_SERVER_URL=http://192.168.0.10:8080

PUBLIC_SERVER_URL=http://10.0.2.2:8080

PUBLIC_WEBSOCKET_URL=ws://localhost:8080/ws-guest-chat

# 임시 userId (JWT 연동 전까지 사용)
TEMP_USER_ID=1
